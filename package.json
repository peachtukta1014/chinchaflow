{
  "name": "chincha-business-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:seafood": "npm run dev --workspace=seafood-pos",
    "dev:tea": "npm run dev --workspace=chincha-tea",
    "build": "npm run build --workspaces --if-present",
    "tea:db-reset": "node scripts/tea-db-reset.mjs --confirm",
    "tea:db-reset:dry": "node scripts/tea-db-reset.mjs --dry-run",
    "tea:db-reset:all": "node scripts/tea-db-reset.mjs --confirm --chincha-db",
    "shrimp:stock-reset": "node scripts/shrimp-stock-reset.mjs --confirm",
    "shrimp:stock-reset:dry": "node scripts/shrimp-stock-reset.mjs --dry-run",
    "shrimp:stock-reset:full": "node scripts/shrimp-stock-reset.mjs --confirm --clear-batches --clear-line-orders"
  },
  "devDependencies": {
    "firebase-admin": "^13.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
