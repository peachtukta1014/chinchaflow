# คัดลอกเป็น apps/seafood-pos/.env.local บนเครื่อง (ไฟล์นี้ commit ได้ — ไม่มีค่าจริง)
# Cloud Agent: ใส่ค่าเดียวกันใน cursor.com → Dashboard → Cloud Agents → Secrets
# อย่า commit .env.local หรือรหัสผ่านลง git

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=chincha-eeed6
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
# กุ้งใช้ APP_ID คนละตัวกับชา (ดู GitHub repo → Settings → Secrets → VITE_FIREBASE_APP_ID_SHRIMP)
VITE_FIREBASE_APP_ID=

# (ทางเลือก) ให้ agent ล็อกอินแอดมินเพื่ออ่าน shrimp_users / E2E — ใส่ใน Secrets เท่านั้น
# SHRIMP_AGENT_EMAIL=peachtukta1014@gmail.com
# SHRIMP_AGENT_PASSWORD=
