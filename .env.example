# =============================================================================
# .env.example — CHINCHA FLOW · ค่า environment ทั้งหมดของโปรเจกต์
# คัดลอกเป็น .env (root) แล้วใส่ค่าจริง — ห้าม commit .env ลง git
# =============================================================================

# ===== 1. OpenRouter API — Flash Agent (จีจี้ แชท · Cloud Function) ===========
# วิธีขอ Key: https://openrouter.ai/keys
# ใช้ใน: aiChatAgentHttp (Cloud Function) — แชท, classify, vision, web search
OPENROUTER_API_KEY=

# ── 4-Tier Model Selection (Flash Agent เท่านั้น) ────────────────────────────
# (ถ้าไม่ใส่ — ใช้ค่า default ในโค้ดอัตโนมัติ)
CHAT_MODEL=deepseek/deepseek-v4-flash    # แชททั่วไป + classify intent (เร็ว/ถูก)
VISION_MODEL=openai/gpt-4o-mini          # มีรูปแนบ (screenshot, สลิป)
SEARCH_MODEL=deepseek/deepseek-chat      # ค้นเว็บ on-demand (OpenRouter web plugin)

# ===== 1b. OpenRouter API — Pro Agent (GitHub Actions เท่านั้น) ================
# ใส่ใน GitHub Secrets: OPENROUTER_API_KEY_PRO (ห้ามใส่ที่นี่หรือ Cloud Function)
# โมเดลที่ใช้: deepseek/deepseek-v4-pro (hardcoded ใน toolDefinitions.js)
# หน้าที่: agentic loop — อ่าน/แก้โค้ด, commit, เปิด PR อัตโนมัติ
OPENROUTER_API_KEY_PRO=

# ===== 2. GitHub PAT =========================================================
# GitHub → Settings → Developer settings → Personal access tokens (classic)

# Flash Agent ใช้ — ส่ง repository_dispatch ให้ Pro Agent เท่านั้น
# Scopes: repo, workflow
GH_PAT_DISPATCH=

# Pro Agent ใช้ (GitHub Actions) — อ่าน/แก้โค้ด + commit + เปิด PR
# Scopes: repo (read/write), workflow
GH_PAT=

# ===== 3. LINE OA — ร้านกุ้ง (webhook-core) ==================================
# LINE Developers → กุ้ง OA → Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Login Channel (สำหรับ verify LIFF token)
# LINE Developers → กุ้ง Login Channel → Channel ID
LINE_LOGIN_CHANNEL_ID=

# LIFF IDs (ถ้าไม่มี = ไม่ติด LIFF — โหมด standalone)
# ดูค่าจริงที่ apps/webhook-core/shrimp-liff-id.json
# LINE_LIFF_ID=
# LINE_LIFF_SLIP_ID=

# ===== 4. LINE OA — ร้านชา (webhook-core + webhook-core-scheduled) ===========
# LINE Developers → ชา OA → Messaging API
LINE_TEA_CHANNEL_ACCESS_TOKEN=

# ===== 5. Firebase (scripts เครื่องมือ admin) =================================
# ใส่เฉพาะรันสคริปต์ reset/prune บนเครื่องตัวเอง
# (Firebase CI ใช้ Service Account Key จาก GitHub Secrets — ไม่ต้องใส่ที่นี่)
FIREBASE_PROJECT_ID=chincha-eeed6

# ===== 6. AI Chat Frontend (apps/ai-chat) =====================================
# URL ของ Cloud Function — เปลี่ยนหลัง deploy ครั้งแรก
# https://asia-southeast1-chincha-eeed6.cloudfunctions.net/aiChatAgentHttp
VITE_AI_CHAT_FUNCTION_URL=

# =============================================================================
# apps/seafood-pos → ดู apps/seafood-pos/.env.example (Firebase + LIFF frontend)
# apps/chincha-tea → ใช้ Firebase config จาก GitHub Secrets ตอน build
# =============================================================================