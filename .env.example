# ===== OpenRouter API (สำหรับ จีจี้ AI Agent) =====
# คัดลอกเป็น .env แล้วใส่ค่าจริง
# วิธีขอ Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── 3-Tier Model Selection (aiChatAgent.js) ──────────────────────────────
# 🟢 Flash  — แชททั่วไป (เร็ว/ถูก)
FLASH_MODEL=deepseek/deepseek-v4-flash

# 🟡 Pro    — โค้ด / วิเคราะห์ complex
CODE_MODEL=deepseek/deepseek-v4-pro

# 🔵 Vision — มีรูปแนบ (screenshot, สลิป, error)
VISION_MODEL=openai/gpt-4o-mini

# ===== GitHub PAT (สำหรับ aiWorkflowAgent — แก้โค้ด + เปิด PR) =====
# วิธีสร้าง: GitHub → Settings → Developer settings → Personal access tokens
# Scopes ที่ต้องการ: repo (read/write), workflow
GH_PAT=

# ===== AI Chat (apps/ai-chat) =====
# URL ของ Cloud Function (เปลี่ยนหลัง deploy ครั้งแรก)
# https://asia-southeast1-chincha-eeed6.cloudfunctions.net/aiChatAgentHttp
VITE_AI_CHAT_FUNCTION_URL=