rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // ใบสั่งของรายวัน (chincha-tea)
    match /orders/{dateKey}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // รูปบิล POS กุ้ง (seafood-pos)
    match /billPhotos/{billId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == ''
        );
    }

    // รูปโปรไฟล์สมาชิกกุ้ง — อัปโหลดได้เฉพาะไฟล์ของตัวเอง
    match /shrimpAvatars/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // รูปโปรไฟล์สมาชิกชา — อัปโหลดได้เฉพาะไฟล์ของตัวเอง
    match /teaAvatars/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // รูปรายการประจำร้าน (chincha-tea restock catalog) — แอดมินอัปโหลดผ่าน RestockForm
    match /catalogImages/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
