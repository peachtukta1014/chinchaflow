{
  "hosting": [
    {
      "target": "shrimp",
      "public": "apps/seafood-pos/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "tea",
      "public": "apps/chincha-tea/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "functions": {
    "source": "apps/webhook-core",
    "runtime": "nodejs22"
  },
  "firestore": [
    {
      "database": "(default)",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    },
    {
      "database": "chincha",
      "rules": "firestore-chincha.rules",
      "indexes": "firestore-chincha.indexes.json"
    }
  ]
}
