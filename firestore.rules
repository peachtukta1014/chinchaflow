rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: must be logged-in Google account
    function isAuth() {
      return request.auth != null;
    }

    // ── Sales bills ─────────────────────────────────────────────────────────
    // Family members can read/write; documents are partitioned by dateKey
    match /sales/{saleId} {
      allow read, write: if isAuth();
    }

    // ── Shared stock level (real-time across all devices) ───────────────────
    match /config/{docId} {
      allow read, write: if isAuth();
    }

    // ── FIFO stock batches ───────────────────────────────────────────────────
    match /stockBatches/{batchId} {
      allow read, write: if isAuth();
    }

    // ── Customer AR (accounts receivable) ───────────────────────────────────
    match /customerDebts/{customerId} {
      allow read, write: if isAuth();
    }

    // ── Chincha Tea orders ───────────────────────────────────────────────────
    match /teaOrders/{orderId} {
      allow read, write: if isAuth();
    }

    // ── Member registry (login/register uses anonymous auth) ─────────────────
    match /members/{phone} {
      allow read, write: if isAuth();
    }
  }
}
