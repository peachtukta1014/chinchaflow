rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Chincha Tea helpers ───────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUser() {
      return userDoc(request.auth.uid);
    }

    function isApproved() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.approved == true;
    }

    function isAdmin() {
      return isApproved() && currentUser().data.role == 'admin';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ─── Seafood POS helpers ───────────────────────────────────────────────────
    function shrimpUserData() {
      return get(/databases/$(database)/documents/shrimp_users/$(request.auth.uid)).data;
    }

    function isApprovedShrimp() {
      return signedIn() && shrimpUserData().approved == true;
    }

    function isAdminShrimp() {
      return isApprovedShrimp() && shrimpUserData().role == 'admin';
    }

    function isChinchaBootstrapAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == 'gmc-peach@chincha.pos';
    }

    function isShrimpBootstrapAdmin() {
      return isChinchaBootstrapAdmin();
    }

    function isTeaBootstrapAdmin() {
      return isChinchaBootstrapAdmin();
    }

    // ─── Chincha Tea collections ───────────────────────────────────────────────

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid)
        && (
          (request.resource.data.role == 'staff' && request.resource.data.approved == false)
          || (isTeaBootstrapAdmin()
            && request.resource.data.role == 'admin'
            && request.resource.data.approved == true)
        );
      allow update: if isAdmin()
        || (isOwner(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.approved == resource.data.approved)
        || (isOwner(uid) && isTeaBootstrapAdmin()
          && request.resource.data.role == 'admin'
          && request.resource.data.approved == true);
      allow delete: if false;
    }

    match /teaOrders/{docId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && request.resource.data.dateKey is string
        && request.resource.data.items is list
        && request.resource.data.total is number
        && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /dailyExpenses/{docId} {
      allow read, create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /products/{docId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /toppings/{docId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /restocks/{docId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.items is list;
      allow update, delete: if isAdmin()
        || (isApproved() && resource.data.uid == request.auth.uid);
    }

    match /orderSlips/{docId} {
      allow read, create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /line_messages/{docId} {
      allow read: if isAdmin() || isAdminShrimp();
      allow create: if false;
      allow update, delete: if isAdmin() || isAdminShrimp();
    }

    // ─── Seafood POS collections ───────────────────────────────────────────────

    // Shrimp user profiles — own doc read/write; list for first-user/approval check
    match /shrimp_users/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if isAdminShrimp();
      allow create: if signedIn() && request.auth.uid == uid
        && (
          (request.resource.data.role == 'staff' && request.resource.data.approved == false)
          || (isShrimpBootstrapAdmin()
            && request.resource.data.role == 'admin'
            && request.resource.data.approved == true)
        );
      allow update: if isAdminShrimp()
        || (signedIn() && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.approved == resource.data.approved)
        || (signedIn() && request.auth.uid == uid && isShrimpBootstrapAdmin()
          && request.resource.data.role == 'admin'
          && request.resource.data.approved == true);
      allow delete: if isAdminShrimp();
    }

    // Sales — approved staff can read/create; admin can update/delete
    match /sales/{docId} {
      allow read, create: if isApprovedShrimp();
      allow update: if isApprovedShrimp();
      allow delete: if isAdminShrimp();
    }

    // Customer debts — staff read/create/update; admin delete
    match /customerDebts/{docId} {
      allow read, create, update: if isApprovedShrimp();
      allow delete: if isAdminShrimp();
    }

    // Stock batches — พนักงานอัปเดตคงเหลือตอนขาย/ย้ายบ่อ (FIFO)
    match /stockBatches/{docId} {
      allow read, create, update: if isApprovedShrimp();
      allow delete: if isAdminShrimp();
    }

    // บันทึกกุ้งตายบ่อ / เสียหาย — ประวัติรายครั้ง
    match /stockAdjustments/{docId} {
      allow read, create: if isApprovedShrimp();
      allow update, delete: if isAdminShrimp();
    }

    // ค่าใช้จ่ายจิปาถะต่อล็อต (สรุปล็อต) — แอดมินบันทึก
    match /lotExpenses/{lotDateKey} {
      allow read: if isApprovedShrimp();
      allow create, update, delete: if isAdminShrimp();
    }

    // Customers list — staff CRUD ลูกค้าที่เพิ่มเอง (cx_*); แอดมินลบได้ทุก doc
    match /customers/{docId} {
      allow read, create, update: if isApprovedShrimp();
      allow delete: if isAdminShrimp()
        || (isApprovedShrimp() && docId.matches('cx_.*'));
    }

    // Config — stock (shrimp), LINE/settings (tea)
    match /config/{docId} {
      allow read: if isApproved() || isApprovedShrimp();
      allow write: if isAdmin() || isAdminShrimp();
      // พนักงานกุ้งรับสต็อก → อัปเดตยอดกุ้งเป็น/ตาย (เฉพาะ config/stock)
      allow update, create: if isApprovedShrimp() && docId == 'stock';
    }

    // Product settings (shrimp prices) — approved read; admin write
    match /productSettings/{docId} {
      allow read: if isApprovedShrimp();
      allow write: if isAdminShrimp();
    }

    // LINE orders — กุ้ง (staff สร้างได้) + ชา (สร้างผ่าน Cloud Functions)
    match /lineOrders/{docId} {
      allow read: if isApproved() || isApprovedShrimp();
      allow create: if isApprovedShrimp();
      allow update: if isApprovedShrimp();
      allow delete: if isAdmin() || isAdminShrimp();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
