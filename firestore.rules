rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Chincha Tea helpers ───────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUser() {
      return userDoc(request.auth.uid);
    }

    function isApproved() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.approved == true;
    }

    function isAdmin() {
      return isApproved() && currentUser().data.role == 'admin';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ─── Seafood POS helpers ───────────────────────────────────────────────────
    function shrimpUserData() {
      return get(/databases/$(database)/documents/shrimp_users/$(request.auth.uid)).data;
    }

    function isApprovedShrimp() {
      return signedIn() && shrimpUserData().approved == true;
    }

    function isAdminShrimp() {
      return isApprovedShrimp() && shrimpUserData().role == 'admin';
    }

    function isManagerShrimp() {
      return isApprovedShrimp() && shrimpUserData().role == 'manager';
    }

    // ลูกมือช่วยส่งของ (role staff ใน Firestore — UI แท็บ LINE)
    function isOperationalStaffShrimp() {
      return isApprovedShrimp() && shrimpUserData().role == 'staff';
    }

    // แอดมิน + สตาฟ (ลูกมือ) — แมนเนเจอร์อ่านอย่างเดียว (สอดคล้อง UI)
    function canMutateShrimpOps() {
      return isApprovedShrimp() && !isManagerShrimp();
    }

    function isChinchaBootstrapAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && (
          request.auth.token.email == 'gmc-peach@chincha.pos'
          || request.auth.token.email == 'peachtukta1014@gmail.com'
        );
    }

    function isShrimpBootstrapAdmin() {
      return isChinchaBootstrapAdmin();
    }

    function isTeaBootstrapAdmin() {
      return isChinchaBootstrapAdmin();
    }

    // ─── Chincha Tea collections ───────────────────────────────────────────────

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid)
        && (
          (request.resource.data.role == 'staff' && request.resource.data.approved == false)
          || (isTeaBootstrapAdmin()
            && request.resource.data.role == 'admin'
            && request.resource.data.approved == true)
        );
      allow update: if isAdmin()
        || (isOwner(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.approved == resource.data.approved)
        || (isOwner(uid) && isTeaBootstrapAdmin()
          && request.resource.data.role == 'admin'
          && request.resource.data.approved == true);
      allow delete: if isAdmin();
    }

    match /teaOrders/{docId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && request.resource.data.dateKey is string
        && request.resource.data.items is list
        && request.resource.data.total is number
        && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /dailyExpenses/{docId} {
      allow read, create: if isApproved();
      allow update, delete: if isAdmin();
    }

    // ลงเวรพนักงานรายวัน — แอดมินติ๊กมือ · ติ๊กอัตโนมัติจากยอดขาย (markedSource sale) เท่านั้น — พนักงานติ๊กมือไม่ได้
    match /dailyStaffAttendance/{docId} {
      allow read: if isApproved();
      allow create, update: if isApproved()
        && request.resource.data.dateKey is string
        && request.resource.data.staffUid is string
        && request.resource.data.present == true
        && (
          isAdmin()
          || request.resource.data.markedSource == 'sale'
        );
      allow delete: if isAdmin();
    }

    // เมนู/ท็อปปิ้ง — พนักงานที่อนุมัติแล้วแก้ได้ (ไม่ต้องเป็นแอดมิน)
    match /products/{docId} {
      allow read: if isApproved();
      allow create, update, delete: if isApproved();
    }

    match /toppings/{docId} {
      allow read: if isApproved();
      allow create, update, delete: if isApproved();
    }

    match /restocks/{docId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.items is list;
      allow update, delete: if isAdmin()
        || (isApproved() && resource.data.uid == request.auth.uid);
    }

    // รายการสั่งของประจำร้าน — พนักงานเพิ่ม/อัปเดตได้ · แอดมินลบได้
    match /restockCatalog/{docId} {
      allow read: if isApproved();
      allow create, update: if isApproved()
        && request.resource.data.name is string
        && request.resource.data.nameKey is string;
      allow delete: if isAdmin();
    }

    match /orderSlips/{docId} {
      allow read, create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /line_messages/{docId} {
      allow read: if isAdmin() || isAdminShrimp();
      allow create: if false;
      allow update, delete: if isAdmin() || isAdminShrimp();
    }

    // ─── Seafood POS collections ───────────────────────────────────────────────

    // Shrimp user profiles — own doc read/write; list for first-user/approval check
    match /shrimp_users/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if isAdminShrimp();
      allow create: if signedIn() && request.auth.uid == uid
        && (
          (request.resource.data.role == 'manager' && request.resource.data.approved == false)
          || (request.resource.data.role == 'staff' && request.resource.data.approved == false)
          || (request.resource.data.role == 'staff' && request.resource.data.approved == true)
          || (isShrimpBootstrapAdmin()
            && request.resource.data.role == 'admin'
            && request.resource.data.approved == true)
        );
      allow update: if isAdminShrimp()
        || (signedIn() && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.approved == resource.data.approved)
        || (signedIn() && request.auth.uid == uid && isShrimpBootstrapAdmin()
          && request.resource.data.role == 'admin'
          && request.resource.data.approved == true);
      allow delete: if isAdminShrimp();
    }

    // Sales — manager อ่านอย่างเดียว · admin/ลูกมือ บันทึกได้
    match /sales/{docId} {
      allow read: if isApprovedShrimp();
      allow create: if canMutateShrimpOps();
      // staff can only adjust payment status — not tamper with totals, items, or customer
      allow update: if isAdminShrimp()
        || (canMutateShrimpOps()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['paymentType', 'paidAmount', 'remainingAmount', 'photoUrl']));
      allow delete: if isAdminShrimp();
    }

    // Customer debts — manager อ่านอย่างเดียว
    match /customerDebts/{docId} {
      allow read: if isApprovedShrimp();
      allow create: if canMutateShrimpOps();
      allow update: if isAdminShrimp()
        || (canMutateShrimpOps()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['totalDebt', 'lastBillNo', 'lastUpdated', 'customerName', 'zone', 'customerId']));
      allow delete: if isAdminShrimp();
    }

    // Stock batches — manager อ่านอย่างเดียว
    match /stockBatches/{docId} {
      allow read: if isApprovedShrimp();
      allow create: if canMutateShrimpOps();
      allow update: if isAdminShrimp()
        || (canMutateShrimpOps()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['remainingLiveKg', 'remainingDeadKg']));
      allow delete: if isAdminShrimp();
    }

    match /stockAdjustments/{docId} {
      allow read: if isApprovedShrimp();
      allow create: if canMutateShrimpOps();
      allow update, delete: if isAdminShrimp();
    }

    match /lotExpenses/{lotDateKey} {
      allow read: if isApprovedShrimp();
      allow create, update: if canMutateShrimpOps();
      allow delete: if isAdminShrimp();
    }

    // สรุปล็อตที่ปิดแล้ว — แอดมินปิด/แก้ไข, พนักงานอ่านได้
    match /lotSummaries/{lotDateKey} {
      allow read: if isApprovedShrimp();
      allow write: if isAdminShrimp();
    }

    match /customers/{docId} {
      allow read: if isApprovedShrimp();
      allow create, update: if canMutateShrimpOps() && !isManagerShrimp();
      allow delete: if isAdminShrimp()
        || (canMutateShrimpOps() && !isManagerShrimp() && docId.matches('cx_.*'));
    }

    // Config — stock (shrimp), LINE/settings (tea)
    match /config/{docId} {
      allow read: if isApproved() || isApprovedShrimp();
      allow write: if isAdmin() || isAdminShrimp();
      // staff อัปเดต config/stock ได้เฉพาะ live/dead/updatedAt เท่านั้น
      allow create: if canMutateShrimpOps()
        && docId == 'stock'
        && request.resource.data.keys().hasOnly(['live', 'dead', 'updatedAt']);
      allow update: if canMutateShrimpOps()
        && docId == 'stock'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['live', 'dead', 'updatedAt']);
    }

    // Product settings (shrimp prices) — approved read; admin write
    match /productSettings/{docId} {
      allow read: if isApprovedShrimp();
      allow write: if isAdminShrimp();
    }

    match /lineOrders/{docId} {
      allow read: if isApproved() || isApprovedShrimp();
      allow create: if canMutateShrimpOps();
      allow update: if isAdmin() || isAdminShrimp()
        || (canMutateShrimpOps()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'status', 'salesId', 'billNo', 'completedAt', 'fulfilledItems',
              'cancelledAt', 'cancelledBy',
              'deliveringAt', 'deliveringBy',
            ]));
      allow delete: if isAdmin() || isAdminShrimp();
    }

    // สลิปโอนจากลูกค้า LINE — สร้างจาก webhook เท่านั้น · ยืนยัน/ปฏิเสธจากแอป
    match /paymentSlipSubmissions/{docId} {
      allow read: if isApprovedShrimp();
      allow create: if false;
      allow update: if canMutateShrimpOps()
        && request.resource.data.status in ['pending', 'confirming', 'confirmed', 'rejected']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'billNo', 'saleId', 'remainingAmount', 'total',
          'confirmedAt', 'confirmedByUid', 'confirmedByName',
          'confirmingAt', 'confirmingByName',
          'rejectedAt', 'rejectedByUid', 'rejectedByName', 'rejectReason',
          'paidBillPushedAt',
        ]);
      allow delete: if isAdminShrimp();
    }

    match /lineBillPushes/{docId} {
      allow read: if isApprovedShrimp();
      allow create, update, delete: if false;
    }

    // แมนเนเจอร์ขอให้แอดมินลบบิล — แจ้งเตือนในแอป + LINE
    match /shrimpAdminAlerts/{docId} {
      allow read: if isAdminShrimp();
      allow create: if isManagerShrimp()
        && request.resource.data.type == 'sale_delete_request'
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedByUid == request.auth.uid;
      allow update: if isAdminShrimp()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'resolvedAt', 'resolvedByUid', 'resolvedByName']);
      allow delete: if isAdminShrimp();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
